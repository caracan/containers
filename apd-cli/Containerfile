FROM ghcr.io/siderolabs/talosctl:v1.12.6@sha256:a027cf02cf74a75eee83ccffa201f3a9455d77e795d092b87cae5e637f143e54 AS talosctl

FROM registry.fedoraproject.org/fedora-toolbox:43@sha256:0a04bf38dd135b5488650d9c8e710049d7e06c98a5c929e469d3cad5a23b16e2

