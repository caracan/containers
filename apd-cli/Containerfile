FROM ghcr.io/siderolabs/talosctl:v1.13.5@sha256:260889d79299fc935eb80cc56ef04d8b609d31674b882dfdbc204374ee6a90e4 AS talosctl

FROM registry.fedoraproject.org/fedora-toolbox:43@sha256:59b55762854a589006596946c3fb33e36067cb8a374a3a112e3d8c319083727e

COPY --from=talosctl /talosctl /usr/local/bin/talosctl

ADD kubernetes.repo /etc/yum.repos.d/

RUN dnf -y install kubectl helm libvirt-client; dnf clean all

